rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Pillar 4: Safely reject everything not explicitly allowed)
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard local test connection support
    match /test/{document} {
      allow read: if true;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Validation helper (Pillar 2: Validation Blueprints / Anti-Update-Gap)
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 100 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128)) &&
             (data.plan == null || data.plan in ['free', 'starter', 'pro', 'elite']) &&
             (data.totalSessions == null || data.totalSessions is number) &&
             (data.streak == null || data.streak is number) &&
             (data.chatsToday == null || data.chatsToday is number) &&
             (data.studyTimeToday == null || data.studyTimeToday is string) &&
             (data.accuracyRate == null || data.accuracyRate is number) &&
             (data.class == null || data.class is string) &&
             (data.board == null || data.board is string) &&
             (data.syllabus == null || data.syllabus is map) &&
             (data.syllabusSources == null || data.syllabusSources is list) &&
             (data.subjects == null || data.subjects is list) &&
             (data.subjectsProgress == null || data.subjectsProgress is map) &&
             (data.flashcardsHistory == null || data.flashcardsHistory is list) &&
             (data.testHistory == null || data.testHistory is list) &&
             (data.flashcards == null || data.flashcards is list);
    }

    // Usage Validation Helper
    function isValidUsage(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.date is string && data.date.size() <= 20 &&
             (data.chatCount == null || data.chatCount is number) &&
             (data.notebookCount == null || data.notebookCount is number);
    }

    // 1. Users Collection Match Block
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'email'])) &&
                    (request.resource.data.plan in ['free', 'starter', 'pro', 'elite']);
      
      // Subcollection tracking
      match /usage/{date} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidUsage(request.resource.data);
        allow delete: if false;
      }
    }

    // 2. Chats Collection Match Block (Pillar 8: Secure List Queries)
    match /chats/{chatId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidId(chatId);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Messages Sub-collection Match Block (Pillar 1: Master Gate - Relational Sync)
      match /messages/{messageId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        allow create, update: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid && isValidId(messageId);
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
      }
    }

    // 3. Notebooks Collection Match Block
    match /notebooks/{notebookId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidId(notebookId);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
