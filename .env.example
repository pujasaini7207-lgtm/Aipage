# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# RAZORPAY_KEY_ID: Required for payments
RAZORPAY_KEY_ID="rzp_test_..."
# RAZORPAY_KEY_SECRET: Required for payments
RAZORPAY_KEY_SECRET="secret_..."

# CASHFREE PAYMENT GATEWAY INTEGRATION
CASHFREE_APP_ID="your_cashfree_app_id_here"
CASHFREE_SECRET_KEY="your_cashfree_secret_key_here"
CASHFREE_MODE="sandbox" # "sandbox" or "production"

# SUPABASE CLIENT CONNECTION (PUBLIC):
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# SUPABASE BACKEND / SECRET SERVICE ROLE KEY (PRIVATE):
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"
